<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:contentDescription="@string/bottom"
    android:background="@color/colorPrimaryDark"
    tools:context=".Main"
    tools:layout_editor_absoluteY="25dp" >

    <ImageView
        android:id="@+id/search_field_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:src="@tools:sample/avatars"
        tools:srcCompat="@drawable/search_field_background" />


    <ImageView
        android:id="@+id/search_icon"
        android:layout_width="30dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="-80dp"
        android:layout_marginTop="30dp"
        android:layout_toEndOf="@+id/search_field"
        android:src="@tools:sample/avatars"
        tools:srcCompat="@drawable/search_icon" />

    <EditText
        android:id="@+id/search_field"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignBottom="@+id/search_field_background"
        android:layout_marginLeft="50dp"
        android:layout_marginRight="90dp"
        android:layout_marginBottom="4dp"
        android:ems="10"
        android:hint="@string/hint_search_field"
        android:inputType="text" />



    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/search_field_background"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/object_background"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:src="@tools:sample/avatars"
                tools:srcCompat="@drawable/object_background" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:src="@tools:sample/avatars"
                tools:srcCompat="@drawable/object_background" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:src="@tools:sample/avatars"
                tools:srcCompat="@drawable/object_background" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TextView" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
